# Retrieve winning tenderers and their awarded amounts for a specific date.
# Filters for rank 1 (winner) and "selected" award status.
# Returns: publication number, winner name, amount, and currency.
# Change the date filter below to adjust the query.

PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX epo: <http://data.europa.eu/a4g/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?publicationNumber ?winnerLegalName ?amount ?currency
WHERE {
  GRAPH ?g {
    # Notice - uses ResultNotice to avoid fetching competition notices
    ?notice a epo:ResultNotice ;
            epo:hasPublicationDate "2024-11-04"^^xsd:date ;
            epo:hasNoticePublicationNumber ?publicationNumber ;
            epo:announcesAwardDecision / epo:comprisesAwardOutcome ?lotAwardOutcome .

    # Only "selected as winner" status, rank 1
    ?lotAwardOutcome epo:hasAwardStatus <http://publications.europa.eu/resource/authority/winner-selection-status/selec-w> ;
                     epo:comprisesTenderAwardOutcome [ epo:hasAwardRank 1 ;
                                                      epo:concernsTender ?tender ] .

    # Tender -> Winner
    ?tender epo:isSubmitedBy / epo:playedBy / epo:hasLegalName ?winnerLegalName ;
            epo:hasFinancialOfferValue ?financialOfferValue .

    # Financial value
    ?financialOfferValue epo:hasAmountValue ?amount ;
                         epo:hasCurrency ?currencyUri .
  }

  ?currencyUri dc:identifier ?currency .
}
